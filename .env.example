# =============================================================================
# AirRaidAlerts — environment configuration template
# -----------------------------------------------------------------------------
# Copy this file to `.env` (`cp .env.example .env`) and fill in real values.
# NEVER commit the real `.env` (it is git-ignored). Values below are PLACEHOLDERS.
# Every variable is preceded by a step-by-step guide for obtaining it from scratch.
# =============================================================================


# -----------------------------------------------------------------------------
# DATABASE_URL  (PostgreSQL — system of record)
# -----------------------------------------------------------------------------
# What: SQLAlchemy 2.0 connection URL for the PostgreSQL database.
# How to set up from scratch:
#   1. Install PostgreSQL 15+:
#        - macOS:  `brew install postgresql@16 && brew services start postgresql@16`
#        - Ubuntu: `sudo apt install postgresql` (service auto-starts)
#        - Docker: `docker run -d --name airraid-pg -e POSTGRES_PASSWORD=changeme \
#                     -p 5432:5432 postgres:16`
#   2. Create the role and database (psql):
#        CREATE ROLE airraid WITH LOGIN PASSWORD 'changeme';
#        CREATE DATABASE airraid OWNER airraid;
#   3. Driver: `pip install "psycopg[binary]"`  -> URL scheme `postgresql+psycopg`.
# Format: postgresql+psycopg://<user>:<password>@<host>:<port>/<dbname>
DATABASE_URL=postgresql+psycopg://airraid:changeme@localhost:5432/airraid

# Discrete parts (optional — used by docker-compose / scripts that build the URL).
# Keep these in sync with DATABASE_URL above.
POSTGRES_USER=airraid
POSTGRES_PASSWORD=changeme
POSTGRES_DB=airraid
POSTGRES_HOST=localhost
POSTGRES_PORT=5432


# -----------------------------------------------------------------------------
# ALERTS_IN_UA_TOKEN  (primary live + historical alert source)
# -----------------------------------------------------------------------------
# What: Personal API token for alerts.in.ua (base URL https://api.alerts.in.ua).
# How to obtain from scratch:
#   1. Open the request form:  https://alerts.in.ua/api-request
#   2. Fill in your name, contact email, and a short description of the use case
#      (e.g. "research / time-series forecasting of air-raid alerts").
#   3. Submit; the team emails the token to the address you provided.
#   4. Read the docs at https://devs.alerts.in.ua/ — auth is either
#      `Authorization: Bearer <token>` or `?token=<token>`.
# Rate limits: soft 8-10 req/min, hard 12 req/min per IP (HTTP 429 over limit);
#              historical endpoint capped at 2 req/min — keep POLL_INTERVAL_SECONDS sane.
ALERTS_IN_UA_TOKEN=replace-with-your-alerts-in-ua-token


# -----------------------------------------------------------------------------
# UKRAINEALARM_API_TOKEN  (fallback alert source)
# -----------------------------------------------------------------------------
# What: API token for the official UkraineAlarm API (https://api.ukrainealarm.com).
# How to obtain from scratch:
#   1. Visit https://api.ukrainealarm.com  and open the API request ("Запит API") form.
#   2. Submit the requested details; you receive a token by the contact method given.
#   3. Auth: send the token in the `Authorization` request header (no "Bearer" prefix).
# Leave blank if you only use alerts.in.ua; the pipeline treats this source as a fallback.
UKRAINEALARM_API_TOKEN=replace-with-your-ukrainealarm-token


# -----------------------------------------------------------------------------
# TELEGRAM_API_ID / TELEGRAM_API_HASH  (OSINT parser — Telethon user client)
# -----------------------------------------------------------------------------
# What: Telegram application credentials so the LangGraph parser can READ public
#       monitoring channels (@kpszsu, @air_alert_ua) via the Telethon MTProto client.
# How to obtain from scratch (one time):
#   1. Go to  https://my.telegram.org  and log in with your Telegram phone number
#      (you receive a login code inside the Telegram app).
#   2. Click "API development tools".
#   3. In the "Create new application" form, set:
#         App title:  airraid-osint        Short name:  airraid
#         Platform:   Desktop  (URL/description optional)
#   4. Submit. The page then shows your `api_id` (an integer) and `api_hash`
#      (a 32-char hex string). Copy both below. Treat api_hash like a password.
TELEGRAM_API_ID=1234567
TELEGRAM_API_HASH=0123456789abcdef0123456789abcdef

# -----------------------------------------------------------------------------
# TELEGRAM_PHONE  (used once to create the login session)
# -----------------------------------------------------------------------------
# What: The phone number (international format, e.g. +380XXXXXXXXX) of the account
#       used to authenticate the Telethon client. Only needed for the first login
#       that generates TELEGRAM_SESSION_STRING below.
TELEGRAM_PHONE=+380000000000

# -----------------------------------------------------------------------------
# TELEGRAM_SESSION_STRING  (persistent auth — avoids re-login on every run)
# -----------------------------------------------------------------------------
# What: A serialized Telethon session so the parser starts without interactive login.
# How to generate from scratch (run once, locally, after API_ID/API_HASH are set):
#   1. `pip install telethon`
#   2. Run this snippet and complete the login prompt (phone code, 2FA if enabled):
#        from telethon.sync import TelegramClient
#        from telethon.sessions import StringSession
#        api_id, api_hash = <TELEGRAM_API_ID>, "<TELEGRAM_API_HASH>"
#        with TelegramClient(StringSession(), api_id, api_hash) as c:
#            print(c.session.save())
#   3. Paste the printed string below. Keep it secret — it grants account access.
TELEGRAM_SESSION_STRING=replace-with-generated-telethon-string-session

# -----------------------------------------------------------------------------
# TELEGRAM_CHANNELS  (channels the OSINT parser subscribes to)
# -----------------------------------------------------------------------------
# What: Comma-separated public channel usernames (no @) for air-tactical warnings.
# Defaults are the two VERIFIED official channels. SECURITY: fake "Air Force"
# clones exist — verify each channel and pin its numeric channel_id in code before
# trusting its messages. Add community monitors only after manual verification.
TELEGRAM_CHANNELS=kpszsu,air_alert_ua


# -----------------------------------------------------------------------------
# LLM_PROVIDER / LLM_MODEL  (LangGraph reasoning backend)
# -----------------------------------------------------------------------------
# What: Selects which LLM the LangGraph OSINT-extraction / reporting agents call.
# Allowed LLM_PROVIDER values: "anthropic" (default) | "openai".
LLM_PROVIDER=anthropic
LLM_MODEL=claude-sonnet-4-6

# -----------------------------------------------------------------------------
# ANTHROPIC_API_KEY  (primary LLM credential — Claude)
# -----------------------------------------------------------------------------
# What: API key for Anthropic's Claude models used by LangGraph.
# How to obtain from scratch:
#   1. Create / log in to an account at  https://console.anthropic.com
#   2. Open  Settings -> API Keys  (https://console.anthropic.com/settings/keys).
#   3. Click "Create Key", name it (e.g. "airraid-langgraph"), copy the value NOW
#      (it is shown only once). Keys start with "sk-ant-".
#   4. Ensure the workspace has billing/credit enabled.
ANTHROPIC_API_KEY=sk-ant-replace-with-your-key

# -----------------------------------------------------------------------------
# OPENAI_API_KEY  (optional alternative LLM credential)
# -----------------------------------------------------------------------------
# What: Only needed if LLM_PROVIDER=openai.
# How to obtain from scratch:
#   1. Log in at  https://platform.openai.com
#   2. Go to  https://platform.openai.com/api-keys  -> "Create new secret key".
#   3. Copy the key (shown once; starts with "sk-"). Add billing under "Billing".
OPENAI_API_KEY=sk-replace-only-if-using-openai


# -----------------------------------------------------------------------------
# OPENWEATHER_API_KEY  (OPTIONAL weather fallback)
# -----------------------------------------------------------------------------
# What: Fallback weather provider. NOT required for normal operation — the primary
#       weather source is Open-Meteo, which needs NO API key
#       (https://open-meteo.com ; historical + 16-day forecast, CC-BY-4.0).
# How to obtain (only if you want the fallback):
#   1. Register at  https://home.openweathermap.org/users/sign_up
#   2. Find your key under  https://home.openweathermap.org/api_keys
#      (new keys can take a short while to activate).
OPENWEATHER_API_KEY=replace-only-if-using-openweathermap-fallback


# -----------------------------------------------------------------------------
# ACLED_API_KEY / ACLED_EMAIL  (OPTIONAL macro conflict-phase enrichment)
# -----------------------------------------------------------------------------
# What: Optional external conflict-event data. The default war-phase signal is
#       DERIVED internally from alert cadence, so these are not required.
# How to obtain (only if you want ACLED enrichment):
#   1. Register at  https://acleddata.com/register/  (approval can take ~1 day).
#   2. Generate an API key in your ACLED account dashboard.
#   3. ACLED requires BOTH the key and the registration email on each request.
ACLED_API_KEY=replace-only-if-using-acled
ACLED_EMAIL=you@example.com


# -----------------------------------------------------------------------------
# Application runtime config
# -----------------------------------------------------------------------------
# RANDOM_SEED        — global seed for deterministic pipeline/ML runs.
# LOG_LEVEL          — DEBUG | INFO | WARNING | ERROR.
# POLL_INTERVAL_SECONDS — alerts.in.ua active poll cadence; keep >=6s so you stay
#                         under the 8-10 req/min soft limit (45s is comfortable).
# ENV                — local | dev | prod (selects config profile).
RANDOM_SEED=42
LOG_LEVEL=INFO
POLL_INTERVAL_SECONDS=45
ENV=local
